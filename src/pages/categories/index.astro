---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = await getCollection('blog');
const catMap = new Map<string, number>();
for (const post of posts) {
	if (post.data.category) {
		catMap.set(post.data.category, (catMap.get(post.data.category) ?? 0) + 1);
	}
}
const categories = [...catMap.entries()].sort((a, b) => b[1] - a[1]);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`カテゴリ一覧 | ${SITE_TITLE}`} description="カテゴリ一覧" />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="section-heading">カテゴリ一覧</h1>
			{categories.length === 0 ? (
				<p class="empty">カテゴリはまだありません。</p>
			) : (
				<ul class="cat-list">
					{categories.map(([cat, count]) => (
						<li class="cat-item">
							<a href={`/categories/${cat}/`} class="cat-link">
								<span class="cat-badge">{cat}</span>
								<span class="cat-name">{cat}</span>
								<span class="cat-count">{count}件</span>
								<span class="arrow">→</span>
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
.cat-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5em; }

.cat-item {
	background: #fff;
	border: 1px solid #e8e8e8;
	border-radius: 6px;
	box-shadow: 0 1px 4px rgba(0,0,0,0.05);
}

.cat-link {
	display: flex;
	align-items: center;
	gap: 0.75em;
	padding: 0.9em 1.25em;
	text-decoration: none;
	color: inherit;
	transition: background 0.15s;
}
.cat-link:hover { background: #fff8f8; text-decoration: none; }

.cat-name { font-weight: 700; font-size: 0.95rem; flex: 1; }
.cat-count { font-size: 0.82rem; color: #999; }
.arrow { color: #CC0000; }

.empty { color: #999; }
</style>
