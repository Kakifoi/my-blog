---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`お問い合わせありがとうございました | ${SITE_TITLE}`} description="お問い合わせを受け付けました。" />
	</head>
	<body>
		<Header />
		<main>
			<div class="thanks-wrap">
				<span class="thanks-icon">✅</span>
				<h1>お問い合わせありがとうございました</h1>
				<p>内容を確認のうえ、通常2〜3日以内にご返信いたします。</p>
				<a href="/" class="btn-home">トップページへ戻る</a>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
.thanks-wrap {
	max-width: 560px;
	margin: 3em auto;
	background: #fff;
	border: 1px solid #e8e8e8;
	border-radius: 8px;
	padding: 3em 2em;
	box-shadow: 0 1px 4px rgba(0,0,0,0.06);
	text-align: center;
}

.thanks-icon {
	font-size: 3rem;
	display: block;
	margin-bottom: 0.75em;
}

h1 {
	font-size: 1.3rem;
	font-weight: 700;
	color: #222;
	margin: 0 0 0.75em;
}

p {
	color: #666;
	font-size: 0.95rem;
	line-height: 1.8;
	margin-bottom: 2em;
}

.btn-home {
	display: inline-block;
	background: #CC0000;
	color: #fff;
	text-decoration: none;
	padding: 0.75em 2.5em;
	border-radius: 5px;
	font-size: 1rem;
	font-weight: 700;
	transition: background 0.15s;
}
.btn-home:hover { background: #aa0000; }
</style>
